# =============================================================================
# OpenMetadata Snowflake pilot — environment configuration
# Copy this file to `.env` and fill in the blanks.
# `.env` is gitignored — NEVER commit real secrets.
# YAML configs under ingestion/connections/ read these via ${VAR} substitution.
# =============================================================================

# --- Platform (docker-compose) ---------------------------------------------
# Fixed project name => deterministic network "openmetadata_app_net".
COMPOSE_PROJECT_NAME=openmetadata
# OpenMetadata release. MUST match the image tags in docker-compose.yml.
OPENMETADATA_VERSION=1.13.0

# --- OpenMetadata server ----------------------------------------------------
# As seen from the HOST (scripts run on your machine):
OM_HOST_URL=http://localhost:8585
# As seen from the ingestion RUNNER container (joins the compose network):
OM_HOST_PORT=http://openmetadata-server:8585/api
OM_DOCKER_NETWORK=openmetadata_app_net
# ingestion-bot JWT — populated by scripts/get-ingestion-token.*  (leave blank)
OM_JWT_TOKEN=

# --- OpenMetadata admin (only used to mint the ingestion-bot token) ---------
OM_ADMIN_EMAIL=admin@open-metadata.org
OM_ADMIN_PASSWORD=admin

# --- Snowflake (non-prod pilot source) -------------------------------------
# Catalog service name shown in OpenMetadata:
SNOWFLAKE_SERVICE_NAME=snowflake_pilot
# Account locator, e.g. ab12345.eu-central-1  or  myorg-myaccount
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
# Auth: prefer key-pair over password (see docs/sources/snowflake.md). Use ONE:
SNOWFLAKE_PASSWORD=
# SNOWFLAKE_PRIVATE_KEY=
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=
# Optional: limit to one database (leave blank to ingest all visible databases).
SNOWFLAKE_DATABASE=
SNOWFLAKE_QUERY_TAG=openmetadata

# --- Smoke test (built-in MySQL of the stack — proves the code path) --------
SMOKE_MYSQL_SERVICE_NAME=local_mysql_smoke
SMOKE_MYSQL_USER=openmetadata_user
SMOKE_MYSQL_PASSWORD=openmetadata_password
SMOKE_MYSQL_DATABASE=openmetadata_db

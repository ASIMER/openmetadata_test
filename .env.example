# =============================================================================
# OpenMetadata local stack — configuration
#   Copy to .env:   cp .env.example .env
# These are LOCAL-TEST values and are SAFE TO COMMIT (no real/prod secrets).
# Variable NAMES match the DevOps task definition, so .env maps 1:1 to the
# deployment — for EKS you only change the VALUES (see the EKS block at the end).
# =============================================================================

# --- Versions (pinned to reproduce the deployed environment) -----------------
OPENMETADATA_VERSION=1.10.0      # OM images (server + ingestion). 1.10.0 => Airflow 2.10.5
POSTGRES_VERSION=16.6            # matches deployed PostgreSQL 16.6
ELASTICSEARCH_VERSION=8.11.4     # search backend shipped with OM 1.10.0

# --- Host ports (change if a port is already taken on your machine) ----------
OM_SERVER_PORT=8585              # OpenMetadata UI + API
OM_ADMIN_PORT=8586               # OpenMetadata health/metrics
POSTGRES_PORT=5432               # Postgres (exposed to host for inspection)
ES_PORT=9200                     # Elasticsearch
AIRFLOW_PORT=8080                # Airflow UI

# =============================================================================
# OpenMetadata -> database   (DevOps env var NAMES; LOCAL values)
# =============================================================================
DB_DRIVER_CLASS=org.postgresql.Driver   # JDBC driver class (Postgres)
DB_SCHEME=postgresql                     # JDBC scheme
DB_HOST=postgresql                       # local: the compose service name
DB_PORT=5432                             # DB port (inside the compose network)
DB_USER=openmetadata_user                # OM application DB user
DB_PASSWORD=openmetadata_password        # OM DB password (compose maps it to OM's DB_USER_PASSWORD)
OM_DATABASE=openmetadata_db              # OM database name
DB_PARAMS=allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC  # JDBC params (local: SSL off)
ENVIRONMENT=local                        # DevOps environment code (informational)
# dbname=postgres                        # DevOps maintenance-DB var; not needed locally

# --- Local Postgres superuser (only for the local container; n/a on EKS) -----
POSTGRES_SUPERUSER=postgres              # superuser that the init script runs as
POSTGRES_SUPERUSER_PASSWORD=password     # local superuser password

# =============================================================================
# Search backend (local Elasticsearch).
# DevOps has NO managed search yet — these names are our own placeholders for now.
# =============================================================================
SEARCH_TYPE=elasticsearch                # elasticsearch | opensearch
ELASTICSEARCH_HOST=elasticsearch         # local: the compose service name
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http

# =============================================================================
# Airflow / ingestion.
# DevOps will use a SEPARATE Airflow instance — these names are our own
# placeholders for now; swap when that instance and its vars are known.
# =============================================================================
AIRFLOW_DB_HOST=postgresql               # local: shares the same Postgres container
AIRFLOW_DB_PORT=5432
AIRFLOW_DB=airflow_db                    # Airflow's own metadata database
AIRFLOW_DB_USER=airflow_user
AIRFLOW_DB_PASSWORD=airflow_pass
AIRFLOW_DB_SCHEME=postgresql+psycopg2
AIRFLOW_USERNAME=admin                   # creds the OM server uses to call Airflow's REST API
AIRFLOW_PASSWORD=admin
PIPELINE_SERVICE_CLIENT_ENDPOINT=http://ingestion:8080    # local Airflow endpoint
SERVER_HOST_API_URL=http://openmetadata-server:8585/api   # how Airflow calls back to OM
FERNET_KEY=jJ/9sz0g0OHxsfxOoSfdFdmk3ysNmPRnH3TUAbz3IHA=   # Airflow secrets encryption (local demo key)

# --- OM server tuning --------------------------------------------------------
OPENMETADATA_CLUSTER_NAME=openmetadata
OPENMETADATA_HEAP_OPTS=-Xmx1G -Xms1G     # JVM heap for the OM server

# =============================================================================
# === ЗАПОЛНИТЬ ДЛЯ EKS  /  TO FILL FOR EKS ===================================
# Keep the variable NAMES above; only change the VALUES to the managed services:
#   DB_HOST / DB_PORT / DB_USER / DB_PASSWORD   -> Aurora Postgres (Secrets Manager)
#   ELASTICSEARCH_HOST / _PORT / _SCHEME        -> managed search (or SEARCH_TYPE=opensearch)
#   PIPELINE_SERVICE_CLIENT_ENDPOINT            -> the real Airflow instance URL
#   AIRFLOW_USERNAME / AIRFLOW_PASSWORD         -> that Airflow's credentials
# On EKS you do NOT run the local postgresql / elasticsearch / ingestion containers —
# you point OM at the managed Aurora / search / Airflow and drop those services.
# =============================================================================

# =============================================================================
# OpenMetadata server — runtime configuration.
# Copy to .env, fill in the values for YOUR deployed services, then:
#   docker run --env-file .env -p 8585:8585 <your-registry>/openmetadata-server:1.10.0
# Variable names are OpenMetadata's standard env vars.
# =============================================================================

# --- Database: your existing PostgreSQL (or MySQL) — REQUIRED ----------------
DB_SCHEME=postgresql                   # postgresql | mysql
DB_DRIVER_CLASS=org.postgresql.Driver  # org.postgresql.Driver | com.mysql.cj.jdbc.Driver
DB_HOST=CHANGE_ME                      # REQUIRED: your DB hostname / endpoint
DB_PORT=5432
OM_DATABASE=openmetadata_db            # the database OpenMetadata uses (must already exist)
DB_USER=openmetadata_user              # REQUIRED
DB_PASSWORD=CHANGE_ME                  # REQUIRED (mapped to DB_USER_PASSWORD inside the container)
DB_PARAMS=allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC  # use SSL in prod

# --- Search: your existing Elasticsearch / OpenSearch — REQUIRED ------------
SEARCH_TYPE=elasticsearch              # elasticsearch | opensearch
ELASTICSEARCH_HOST=CHANGE_ME           # REQUIRED: your search host / endpoint
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http              # http | https
# ELASTICSEARCH_USER=
# ELASTICSEARCH_PASSWORD=

# --- Airflow / pipeline service: your existing Airflow — optional -----------
# Set PIPELINE_SERVICE_CLIENT_ENABLED=false if you don't use UI-driven ingestion.
PIPELINE_SERVICE_CLIENT_ENABLED=true
PIPELINE_SERVICE_CLIENT_ENDPOINT=http://CHANGE_ME:8080     # your Airflow URL
SERVER_HOST_API_URL=http://CHANGE_ME:8585/api              # how Airflow calls back to this server
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=CHANGE_ME

# --- Server runtime — optional ----------------------------------------------
OM_MIGRATE_ON_START=true               # run DB migrations when the container starts
OPENMETADATA_HEAP_OPTS=-Xmx1G -Xms1G   # JVM heap
# Auth defaults to basic (admin@open-metadata.org / admin). Replace the demo key in prod:
FERNET_KEY=jJ/9sz0g0OHxsfxOoSfdFdmk3ysNmPRnH3TUAbz3IHA=
